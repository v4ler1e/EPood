@page "/products"

@using EPood.Blazor.Models
@using EPood.Blazor.Services

@inject ProductService ProductService

<h3>Products</h3>

<EditForm Model="ProductForm" OnValidSubmit="SaveProduct">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-2">
        <label>Name</label>
        <InputText class="form-control" @bind-Value="ProductForm.Name" />
    </div>

    <div class="mb-2">
        <label>Description</label>
        <InputText class="form-control" @bind-Value="ProductForm.Description" />
    </div>

    <div class="mb-2">
        <label>Price</label>
        <InputNumber class="form-control" @bind-Value="ProductForm.Price" />
    </div>

    <div class="mb-2">
        <label>Stock</label>
        <InputNumber class="form-control" @bind-Value="ProductForm.Stock" />
    </div>

    <div class="mb-2">
        <label>Category</label>
        <InputSelect class="form-control" @bind-Value="ProductForm.CategoryId">
            <option value="0">Select category</option>

            @foreach (var category in Categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </InputSelect>
    </div>

    <button class="btn btn-primary" type="submit">
        Save
    </button>

    <button class="btn btn-secondary ms-2" type="button" @onclick="ClearForm">
        Clear
    </button>
</EditForm>

<br />

<div class="d-flex mb-3">
    <input class="form-control me-2"
           placeholder="Search products..."
           @bind="SearchText" />

    <button class="btn btn-primary"
            @onclick="SearchProducts">
        Search
    </button>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Description</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Category</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var product in ProductList)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Description</td>
                <td>@product.Price</td>
                <td>@product.Stock</td>
                <td>@product.CategoryName</td>
                <td>
                    <button class="btn btn-warning btn-sm"
                            @onclick="() => EditProduct(product)">
                        Edit
                    </button>

                    <button class="btn btn-danger btn-sm ms-2"
                            @onclick="() => DeleteProduct(product.Id)">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex align-items-center mt-3">
    <button class="btn btn-secondary me-2"
            @onclick="PreviousPage"
            disabled="@(Page <= 1)">
        Previous
    </button>

    <span>Page @Page of @TotalPages</span>

    <button class="btn btn-secondary ms-2"
            @onclick="NextPage"
            disabled="@(Page >= TotalPages)">
        Next
    </button>
</div>

@code {
    private List<ProductModel> ProductList = new();

    private List<CategoryModel> Categories = new();

    private SaveProductModel ProductForm = new();

    private string SearchText = "";

    private int Page = 1;

    private int PageSize = 5;

    private int TotalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
        Categories = await ProductService.GetCategories();
    }

    private async Task LoadProducts()
    {
        var result = await ProductService.GetProducts(
            SearchText,
            Page,
            PageSize);

        ProductList = result.Items;
        TotalPages = result.TotalPages;
    }

    private async Task SearchProducts()
    {
        Page = 1;
        await LoadProducts();
    }

    private async Task PreviousPage()
    {
        if (Page > 1)
        {
            Page--;
            await LoadProducts();
        }
    }

    private async Task NextPage()
    {
        if (Page < TotalPages)
        {
            Page++;
            await LoadProducts();
        }
    }

    private async Task SaveProduct()
    {
        if (ProductForm.Id == 0)
        {
            await ProductService.AddProduct(ProductForm);
        }
        else
        {
            await ProductService.UpdateProduct(ProductForm);
        }

        ClearForm();

        await LoadProducts();
    }

    private void EditProduct(ProductModel product)
    {
        ProductForm = new SaveProductModel
            {
                Id = product.Id,
                Name = product.Name,
                Description = product.Description,
                Price = product.Price,
                Stock = product.Stock,
                CategoryId = product.CategoryId
            };
    }

    private async Task DeleteProduct(int id)
    {
        await ProductService.DeleteProduct(id);
        await LoadProducts();
    }

    private void ClearForm()
    {
        ProductForm = new SaveProductModel();
    }
}