@page "/orders"

@using EPood.Blazor.Models
@using EPood.Blazor.Services

@inject ProductService ProductService

<h3>Orders</h3>

<EditForm Model="OrderForm" OnValidSubmit="SaveOrder">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-2">
        <label>Customer name</label>
        <InputText class="form-control" @bind-Value="OrderForm.CustomerName" />
    </div>

    <div class="mb-2">
        <label>Product</label>
        <InputSelect class="form-control" @bind-Value="OrderForm.ProductId">
            @foreach (var product in Products)
            {
                <option value="@product.Id">@product.Name</option>
            }
        </InputSelect>
    </div>

    <div class="mb-2">
        <label>Quantity</label>
        <InputNumber class="form-control" @bind-Value="OrderForm.Quantity" />
    </div>

    <button class="btn btn-primary" type="submit">
        @(OrderForm.Id == 0 ? "Add" : "Update")
    </button>

    <button class="btn btn-secondary ms-2" type="button" @onclick="ClearForm">
        Clear
    </button>
</EditForm>

<br />

<div class="d-flex mb-3">
    <input class="form-control me-2"
           placeholder="Search orders..."
           @bind="SearchText" />

    <button class="btn btn-primary"
            @onclick="SearchOrders">
        Search
    </button>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th @onclick="@(() => SortOrders("customer"))">Customer</th>
            <th @onclick="@(() => SortOrders("date"))">Date</th>
            <th @onclick="@(() => SortOrders("product"))">Product</th>
            <th @onclick="@(() => SortOrders("quantity"))">Quantity</th>
            <th @onclick="@(() => SortOrders("totalPrice"))">Total price</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var order in OrderList)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.CustomerName</td>
                <td>@order.CreatedAt.ToString("g")</td>
                <td>@order.ProductName</td>
                <td>@order.Quantity</td>
                <td>@order.TotalPrice</td>
                <td>
                    <button class="btn btn-warning btn-sm"
                            @onclick="() => EditOrder(order)">
                        Edit
                    </button>

                    <button class="btn btn-danger btn-sm ms-2"
                            @onclick="() => DeleteOrder(order.Id)">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex align-items-center mt-3">
    <button class="btn btn-secondary me-2"
            @onclick="PreviousPage"
            disabled="@(Page <= 1)">
        Previous
    </button>

    <span>Page @Page of @TotalPages</span>

    <button class="btn btn-secondary ms-2"
            @onclick="NextPage"
            disabled="@(Page >= TotalPages)">
        Next
    </button>
</div>

@code {
    private List<OrderModel> OrderList = new();

    private List<ProductModel> Products = new();

    private SaveOrderModel OrderForm = new();

    private string SearchText = "";

    private int Page = 1;

    private int PageSize = 5;

    private int TotalPages = 1;

    private string SortBy = "";

    private bool Descending = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
        await LoadOrders();

        if (Products.Any())
        {
            OrderForm.ProductId = Products.First().Id;
        }
    }

    private async Task LoadOrders()
    {
        var result = await ProductService.GetOrders(
            SearchText,
            Page,
            PageSize,
            SortBy,
            Descending);

        OrderList = result.Items;
        TotalPages = result.TotalPages;
    }

    private async Task LoadProducts()
    {
        var result = await ProductService.GetProducts(null, 1, 100);
        Products = result.Items;
    }

    private async Task SearchOrders()
    {
        Page = 1;
        await LoadOrders();
    }

    private async Task SortOrders(string sortField)
    {
        if (SortBy == sortField)
        {
            Descending = !Descending;
        }
        else
        {
            SortBy = sortField;
            Descending = false;
        }

        Page = 1;
        await LoadOrders();
    }

    private async Task PreviousPage()
    {
        if (Page > 1)
        {
            Page--;
            await LoadOrders();
        }
    }

    private async Task NextPage()
    {
        if (Page < TotalPages)
        {
            Page++;
            await LoadOrders();
        }
    }

    private async Task SaveOrder()
    {
        if (OrderForm.Id == 0)
        {
            await ProductService.AddOrder(OrderForm);
        }
        else
        {
            await ProductService.UpdateOrder(OrderForm);
        }

        ClearForm();

        await LoadOrders();
    }

    private void EditOrder(OrderModel order)
    {
        OrderForm = new SaveOrderModel
            {
                Id = order.Id,
                CustomerName = order.CustomerName,
                ProductId = order.ProductId,
                Quantity = order.Quantity
            };
    }

    private async Task DeleteOrder(int id)
    {
        await ProductService.DeleteOrder(id);
        await LoadOrders();
    }

    private void ClearForm()
    {
        OrderForm = new SaveOrderModel
            {
                ProductId = Products.Any() ? Products.First().Id : 0,
                Quantity = 1
            };
    }
}